<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio Visualizer Studio"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSelectAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ВЫБРАТЬ АУДИОЗАПИСЬ (MP3/WAV)"
            android:backgroundTint="#212121"
            android:textColor="#FFFFFF"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Аудио не выбрано"
            android:textColor="#B0B0B0"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnSelectBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ВЫБРАТЬ ФОНОВОЕ ИЗОБРАЖЕНИЕ"
            android:backgroundTint="#212121"
            android:textColor="#FFFFFF"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tvBackgroundStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фон не выбран"
            android:textColor="#B0B0B0"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="12dp"
            app:indicatorColor="#FF00FF"/>

        <TextView
            android:id="@+id/tvGlobalStatus"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="220dp"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:textColor="#FF00FF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="start|top"
            android:scrollbars="vertical"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СОЗДАТЬ ВИДЕОРОЛИК"
            android:backgroundTint="#FF00FF"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>