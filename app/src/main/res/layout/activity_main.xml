<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F172A"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Audio Visualizer Studio"
            android:textColor="#F8FAFC"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btnSelectAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ВЫБРАТЬ АУДИОЗАПИСЬ"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="14dp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Аудио не выбрано"
            android:textColor="#94A3B8"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSelectBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ВЫБРАТЬ ФОНОВОЕ ИЗОБРАЖЕНИЕ"
            android:backgroundTint="#334155"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="14dp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/tvBackgroundStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фон не выбран (будет черный экран)"
            android:textColor="#94A3B8"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:indicatorColor="#38BDF8"/>

        <TextView
            android:id="@+id/tvGlobalStatus"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="260dp"
            android:background="#1E293B"
            android:padding="14dp"
            android:textColor="#E2E8F0"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:gravity="start|top"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СОЗДАТЬ ВИДЕОРОЛИК"
            android:backgroundTint="#0284C7"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:padding="16dp"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>